<Window x:Class="GreatRed.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GreatRed"
        mc:Ignorable="d"
        Title="Premium UID Bypass Console" 
        Height="372" Width="492"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        RenderOptions.EdgeMode="Unspecified"
        RenderOptions.ClearTypeHint="Enabled">

    <Window.Resources>
        <!-- CRT Scanline Visual Brush -->
        <VisualBrush x:Key="ScanlinesBrush" TileMode="Tile" Viewport="0,0,3,3" ViewportUnits="Absolute">
            <VisualBrush.Visual>
                <Grid Width="3" Height="3" Background="Transparent">
                    <!-- Horizontal scanline -->
                    <Line X1="0" Y1="0" X2="3" Y2="0" Stroke="#000000" StrokeThickness="0.8" Opacity="0.22"/>
                    <!-- Vertical RGB mask tint -->
                    <Line X1="0" Y1="0" X2="0" Y2="3" Stroke="#FF1E56" StrokeThickness="0.5" Opacity="0.02"/>
                </Grid>
            </VisualBrush.Visual>
        </VisualBrush>

        <!-- Base Button Style -->
        <Style x:Key="ImguiButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource WidgetBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WidgetBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="4" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#181616"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#88FF1E56"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FF1E56"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource CrimsonBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent/Link Button Style -->
        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ImguiButtonStyle}">
            <Setter Property="Background" Value="#19FF1E56"/>
            <Setter Property="BorderBrush" Value="#80FF1E56"/>
            <Setter Property="Foreground" Value="{StaticResource CrimsonBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="5" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CrimsonBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource CrimsonBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CrimsonActiveBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green Button Style -->
        <Style x:Key="GreenButtonStyle" TargetType="Button" BasedOn="{StaticResource ImguiButtonStyle}">
            <Setter Property="Background" Value="#1400E676"/>
            <Setter Property="BorderBrush" Value="#7300E676"/>
            <Setter Property="Foreground" Value="#00FF66"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="4" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00C853"/>
                                <Setter Property="Foreground" Value="#000000"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00FF88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00991F"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red Button Style -->
        <Style x:Key="RedButtonStyle" TargetType="Button" BasedOn="{StaticResource ImguiButtonStyle}">
            <Setter Property="Background" Value="#14FF1E56"/>
            <Setter Property="BorderBrush" Value="#73FF1E56"/>
            <Setter Property="Foreground" Value="#FF3E72"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="4" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CrimsonBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF3E72"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CrimsonActiveBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Tab Button Style -->
        <Style x:Key="SidebarTabStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="5" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CrimsonDimBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4DFF1E56"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dynamic LED Pulsing Animation -->
        <Storyboard x:Key="LedPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="BypassLedGlow" Storyboard.TargetProperty="Opacity"
                             From="0.2" To="1.0" Duration="0:0:0.9"/>
            <DoubleAnimation Storyboard.TargetName="BypassLedScale" Storyboard.TargetProperty="ScaleX"
                             From="0.9" To="1.15" Duration="0:0:0.9"/>
            <DoubleAnimation Storyboard.TargetName="BypassLedScale" Storyboard.TargetProperty="ScaleY"
                             From="0.9" To="1.15" Duration="0:0:0.9"/>
        </Storyboard>
    </Window.Resources>

    <!-- Main Outer Canvas to prevent clipping of borders or effects -->
    <Grid Name="MainRootGrid" ClipToBounds="False">
        
        <!-- The window container, styled to match the ImGui window -->
        <Border Name="ImguiWindowBorder" 
                Width="412" Height="312"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="6">
            
            <!-- Render transform for dragging tilt effect -->
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="WindowScale" ScaleX="1.0" ScaleY="1.0" CenterX="206" CenterY="146"/>
                    <RotateTransform x:Name="WindowRotation" Angle="0" CenterX="206" CenterY="146"/>
                </TransformGroup>
            </Border.RenderTransform>

            <Grid>
                <!-- Backing border for shadow and background (separated to preserve ClearType text rendering) -->
                <Border Name="ImguiWindowBg"
                        Background="{StaticResource PanelBgBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        IsHitTestVisible="False">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF1E56" BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>
                </Border>

                <!-- Content layer -->
                <Border CornerRadius="6" BorderThickness="1" BorderBrush="Transparent" ClipToBounds="True">
                    <Grid Name="ImguiWindowContentGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 1. DRAGGABLE TITLEBAR -->
                <Grid Grid.Row="0" Name="TitleBarDragGrid" MouseDown="TitleBarDragGrid_MouseDown">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0A0909" Offset="0"/>
                            <GradientStop Color="#0F0E0E" Offset="0.6"/>
                            <GradientStop Color="#0AFF1E56" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- Title Text -->
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="PREMIUM" FontWeight="ExtraBold" FontSize="11" Foreground="{StaticResource CrimsonBrush}"/>
                        <TextBlock Text=" UID BYPASS" FontWeight="ExtraBold" FontSize="11" Foreground="{StaticResource TextHighlightBrush}" Margin="4,0,0,0"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                        <!-- Minimize Button -->
                        <Button Width="18" Height="18" Margin="0,0,6,0" BorderThickness="0" Background="#C8FFBA00" Cursor="Hand" Click="MinimizeButton_Click" ToolTip="Minimize">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="6" Background="{TemplateBinding Background}">
                                        <TextBlock Text="−" Foreground="#CC000000" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Close Button -->
                        <Button Width="18" Height="18" BorderThickness="0" Background="#CCFF3232" Cursor="Hand" Click="CloseButton_Click" ToolTip="Close">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="6" Background="{TemplateBinding Background}">
                                        <TextBlock Text="×" Foreground="#CC000000" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Titlebar Top Gradient Edge Line -->
                    <Border Height="1" VerticalAlignment="Top" Opacity="0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="{StaticResource CrimsonColor}" Offset="0.4"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    
                    <!-- Titlebar Bottom Border -->
                    <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource PanelBorderBrush}" VerticalAlignment="Bottom"/>
                </Grid>

                <!-- 2. CONTENT CONTAINER -->
                <Grid Grid.Row="1" Name="ContentContainerGrid">
                    
                    <!-- ==================== A. SIGN IN PAGE ==================== -->
                    <Grid Name="LoginPage" Visibility="Visible" Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Login Container Card -->
                        <Border Width="266" Padding="21,19" CornerRadius="10" 
                                BorderBrush="#26FF1E56" BorderThickness="1"
                                Background="#F20A0909">
                            
                            <StackPanel HorizontalAlignment="Stretch">
                                <!-- Top Accent Border -->
                                <Border Height="2" Margin="-18,-16,-18,6" VerticalAlignment="Top" CornerRadius="1,1,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="{StaticResource CrimsonColor}" Offset="0.5"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <!-- Lock Icon -->
                                <Border Width="42" Height="42" Margin="0,10,0,0" CornerRadius="10" Background="#14FF1E56" BorderBrush="#33FF1E56" BorderThickness="1" HorizontalAlignment="Center">
                                    <Path Data="M 3 13 A 2 2 0 0 1 5 11 H 19 A 2 2 0 0 1 21 13 V 20 A 2 2 0 0 1 19 22 H 5 A 2 2 0 0 1 3 20 Z M 7 11 V 7 A 5 5 0 0 1 17 7 V 11" 
                                          Stroke="{StaticResource CrimsonBrush}" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center" Width="24" Height="24" Stretch="Uniform"/>
                                </Border>

                                <!-- Title -->
                                <TextBlock Text="AUTHENTICATION REQUIRED" Margin="0,10,0,0" FontWeight="ExtraBold" FontSize="11" Foreground="{StaticResource TextHighlightBrush}" HorizontalAlignment="Center"/>
                                
                                <Border Width="30" Height="2" Margin="0,10,0,0" Background="{StaticResource CrimsonBrush}" CornerRadius="1" HorizontalAlignment="Center"/>

                                <!-- Inputs -->
                                <StackPanel Margin="0,14,0,0">
                                    <!-- Username Input -->
                                    <Grid>
                                        <!-- User SVG Icon -->
                                        <Path Data="M 20 21 V 19 A 4 4 0 0 0 16 15 H 8 A 4 4 0 0 0 4 19 V 21 M 12 11 A 4 4 0 1 0 12 3 A 4 4 0 1 0 12 11 Z" 
                                              Stroke="{StaticResource TextMutedBrush}" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" Width="14" Height="14" Stretch="Uniform" Panel.ZIndex="10"/>
                                        <TextBox Name="TxtUsername" Height="38" Padding="35,3,13,3" VerticalContentAlignment="Center" Background="#070707" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" Foreground="{StaticResource TextMainBrush}" FontSize="12" KeyDown="LoginInput_KeyDown">
                                            <TextBox.Resources>
                                                <!-- Placeholder implementation -->
                                                <VisualBrush x:Key="HintBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="USERNAME" Foreground="{StaticResource TextMutedBrush}" FontSize="11" FontWeight="Bold" Margin="35,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </TextBox.Resources>
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource CrimsonBrush}"/>
                                                            <Setter Property="Background" Value="#070707"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>

                                    <!-- Password Input -->
                                    <Grid Margin="0,8,0,0">
                                        <!-- Lock SVG Icon -->
                                        <Path Data="M 3 13 A 2 2 0 0 1 5 11 H 19 A 2 2 0 0 1 21 13 V 20 A 2 2 0 0 1 19 22 H 5 A 2 2 0 0 1 3 20 Z M 7 11 V 7 A 5 5 0 0 1 17 7 V 11" 
                                              Stroke="{StaticResource TextMutedBrush}" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0" Width="14" Height="14" Stretch="Uniform" Panel.ZIndex="10"/>
                                        <PasswordBox Name="TxtPassword" Height="38" Padding="35,3,13,3" VerticalContentAlignment="Center" Background="#070707" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" Foreground="{StaticResource TextMainBrush}" FontSize="12" KeyDown="LoginInput_KeyDown" PasswordChanged="TxtPassword_PasswordChanged">
                                            <!-- PasswordBox placeholder hack -->
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource CrimsonBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>
                                        <!-- Placeholder Text block (visible only when empty and not focused) -->
                                        <TextBlock Name="PasswordPlaceholder" IsHitTestVisible="False" Text="PASSWORD" Foreground="{StaticResource TextMutedBrush}" FontSize="11" FontWeight="Bold" Margin="35,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Sign In Button -->
                                <Button Content="SIGN IN" Height="42" Margin="0,14,0,0" Cursor="Hand" Click="SignInButton_Click" Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Name="btnBorder" CornerRadius="8" BorderBrush="#72FF1E56" BorderThickness="1">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{StaticResource CrimsonColor}" Offset="0"/>
                                                        <GradientStop Color="{StaticResource CrimsonActiveColor}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}">
                                                    <ContentPresenter.Resources>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontWeight" Value="ExtraBold"/>
                                                            <Setter Property="FontSize" Value="12"/>
                                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                                            
                                                        </Style>
                                                    </ContentPresenter.Resources>
                                                </ContentPresenter>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnBorder" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="{StaticResource CrimsonHoverColor}" Offset="0"/>
                                                                <GradientStop Color="{StaticResource CrimsonColor}" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="btnBorder" Property="BorderBrush" Value="{StaticResource CrimsonHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="0.96" ScaleY="0.96" CenterX="110" CenterY="18"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <TextBlock Text="Enter credentials to access the console" Margin="0,10,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="9" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ==================== B. RESOURCE DOWNLOADING PAGE ==================== -->
                    <Grid Name="DownloadPage" Visibility="Collapsed" Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="326" Padding="31,27" CornerRadius="10" 
                                BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1"
                                Background="#F20A0909">

                            <StackPanel>
                                <!-- Top Accent Border -->
                                <Border Height="3" Margin="-28,-24,-28,4" VerticalAlignment="Top" CornerRadius="1,1,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="{StaticResource CrimsonColor}" Offset="0.5"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <!-- Cloud SVG Icon -->
                                <Border Width="46" Height="46" Margin="0,16,0,0" HorizontalAlignment="Center">
                                    <Path Data="M21.2 15c.9-1.2 1-2.9.2-4-1-1.6-3-2-4.7-1.3-.4-2.7-2-4.7-4.3-4.7-3 0-5.4 2.4-5.4 5.4H7A4 4 0 0 0 3 14c0 2.2 1.8 4 4 4h10c2.2 0 4-1.8 4-4z M 8 12 L 12 16 L 16 12 M 12 8 V 16" 
                                          Stroke="{StaticResource CrimsonBrush}" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center" Width="42" Height="42" Stretch="Uniform"/>
                                </Border>

                                <!-- Title -->
                                <TextBlock Text="DOWNLOADING RESOURCES" Margin="0,16,0,0" FontWeight="ExtraBold" FontSize="13" Foreground="{StaticResource TextHighlightBrush}" HorizontalAlignment="Center"/>

                                <!-- Stats -->
                                <Grid Margin="0,20,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Size Stats -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Size Left:" FontFamily="Monospace" FontSize="13" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Name="LblDownloadSize" Text="32.0 MB" FontFamily="Monospace" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/>

                                    <!-- Speed Stats -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Speed:" FontFamily="Monospace" FontSize="13" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Name="LblDownloadSpeed" Text="0.0 MB/s" FontFamily="Monospace" FontSize="13" FontWeight="Bold" Foreground="#00FF66" Margin="0,4,0,0"/>
                                </Grid>

                                <!-- Progress bar -->
                                <Border Height="12" Margin="0,16,0,0" CornerRadius="3" Background="#070707" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1">
                                    <Grid HorizontalAlignment="Left">
                                        <Border Name="DownloadProgressBar" CornerRadius="2" Width="0" Background="{StaticResource CrimsonBrush}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ==================== C. MAIN APP WORKSPACE ==================== -->
                    <Grid Name="MainAppWorkspace" Visibility="Collapsed" Margin="0" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- COLUMN 0: SIDEBAR -->
                        <Grid Grid.Column="0" Background="#F20A0909" Margin="0,0,0,0">
                            <!-- Sidebar Right Border -->
                            <Border BorderThickness="0,0,1,0" BorderBrush="{StaticResource PanelBorderBrush}" HorizontalAlignment="Right"/>
                            
                            <!-- Sliding Tab Indicator -->
                            <Border Name="SidebarIndicator" Width="8" Height="24" HorizontalAlignment="Left" Background="{StaticResource CrimsonBrush}" CornerRadius="1" VerticalAlignment="Top">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="IndicatorTransform" Y="13"/>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF1E56" BlurRadius="8" ShadowDepth="0" Opacity="1.0"/>
                                </Border.Effect>
                            </Border>

                            <!-- Tab Button Stack -->
                            <StackPanel Margin="0,8" HorizontalAlignment="Center">
                                <!-- Tab 1: Security -->
                                <Button Name="TabBtn1" Style="{StaticResource SidebarTabStyle}" Tag="0" Click="TabButton_Click" ToolTip="Security Check">
                                    <Path Data="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" 
                                          Stroke="{StaticResource TextMutedBrush}" StrokeThickness="2.5" Width="20" Height="20" Stretch="Uniform"/>
                                </Button>
                                <!-- Tab 2: Bypass -->
                                <Button Name="TabBtn2" Style="{StaticResource SidebarTabStyle}" Tag="1" Margin="0,4,0,0" Click="TabButton_Click" ToolTip="Bypass Config">
                                    <Path Data="M 5 3 L 19 12 L 5 21 Z" 
                                          Stroke="{StaticResource TextMutedBrush}" StrokeThickness="2.5" Width="20" Height="20" Stretch="Uniform"/>
                                </Button>
                                <!-- Tab 3: Emulator -->
                                <Button Name="TabBtn3" Style="{StaticResource SidebarTabStyle}" Tag="2" Margin="0,4,0,0" Click="TabButton_Click" ToolTip="Installer Menu">
                                    <Path Data="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" 
                                          Stroke="{StaticResource TextMutedBrush}" StrokeThickness="2.5" Width="20" Height="20" Stretch="Uniform"/>
                                </Button>
                                <!-- Tab 4: Portal -->
                                <Button Name="TabBtn4" Style="{StaticResource SidebarTabStyle}" Tag="3" Margin="0,4,0,0" Click="TabButton_Click" ToolTip="Profile &amp; Support">
                                    <Path Data="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M16 7 A 4 4 0 1 1 8 7 A 4 4 0 1 1 16 7" 
                                          Stroke="{StaticResource TextMutedBrush}" StrokeThickness="2.5" Width="20" Height="20" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- COLUMN 1: WORKSPACE PAGES -->
                        <Grid Grid.Column="1" Name="PagesContainerGrid" Margin="10,8">
                            
                             <!-- PAGE 0: SECURITY SCAN -->
                             <Grid Name="PageSecurity" Visibility="Visible" VerticalAlignment="Center">
                                <Border CornerRadius="6" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" Padding="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#120C0D" Offset="0"/>
                                            <GradientStop Color="#0A0909" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <!-- Header -->
                                        <Border Padding="10,8,10,7" BorderThickness="0,0,0,1" BorderBrush="{StaticResource WidgetBorderBrush}">
                                            <Grid>
                                                <TextBlock Text="SECURITY INTEGRITY" FontWeight="ExtraBold" FontSize="11" Foreground="#00FF33" VerticalAlignment="Center"/>
                                                <TextBlock Text="SYSTEM SHIELD" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
 
                                        <!-- Content -->
                                        <StackPanel Margin="13">
                                            <!-- Bypass Status -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Kernel Anticheat Bypass" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas, Courier New" FontSize="11"/>
                                                <TextBlock Name="StatusBypass" Text="SECURE" Foreground="#00FF66" FontWeight="Bold" FontFamily="Consolas, Courier New" FontSize="12" HorizontalAlignment="Right">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect Color="#00FF66" BlurRadius="6" ShadowDepth="0" Opacity="0.25"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                            </Grid>
 
                                            <!-- Memory Integrity -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Memory Integrity" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas, Courier New" FontSize="11"/>
                                                <TextBlock Name="StatusMemory" Text="SAFE" Foreground="#00FF66" FontWeight="Bold" FontFamily="Consolas, Courier New" FontSize="12" HorizontalAlignment="Right">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect Color="#00FF66" BlurRadius="6" ShadowDepth="0" Opacity="0.25"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                            </Grid>
 
                                            <!-- Anti-Debugging -->
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Anti-Debugging Shield" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas, Courier New" FontSize="11"/>
                                                <TextBlock Name="StatusDebug" Text="ACTIVE" Foreground="#00FF66" FontWeight="Bold" FontFamily="Consolas, Courier New" FontSize="12" HorizontalAlignment="Right">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect Color="#00FF66" BlurRadius="6" ShadowDepth="0" Opacity="0.25"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                            </Grid>

                                            <!-- Progress Bar (Scanning) -->
                                            <Border Name="SecurityProgressContainer" Visibility="Collapsed" Height="4" CornerRadius="2" Background="#141212" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" Margin="0,2,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition x:Name="SecurityProgressColDone" Width="0*"/>
                                                        <ColumnDefinition x:Name="SecurityProgressColLeft" Width="100*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#00FF66" CornerRadius="1"/>
                                                </Grid>
                                            </Border>

                                            <!-- Scan Button -->
                                            <Button Name="BtnSecurityScan" Content="SCAN SYSTEM" Style="{StaticResource GreenButtonStyle}" Height="26" FontSize="11" Margin="0,2,0,0" Click="BtnSecurityScan_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- PAGE 1: BYPASS CONFIG -->
                             <Grid Name="PageBypass" Visibility="Collapsed" VerticalAlignment="Center">
                                <Border CornerRadius="6" BorderBrush="#1A1A1A" BorderThickness="1" Padding="13,15" Background="#0B0B0B">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
 
                                         <!-- Game Icon -->
                                         <Border Grid.Column="0" Width="54" Height="54" CornerRadius="6" BorderBrush="#0FFFFFFF" BorderThickness="1" Margin="0,0,10,0" ClipToBounds="True">
                                             <Image Source="pack://application:,,,/GreatRed;component/freefire.png" RenderOptions.BitmapScalingMode="HighQuality" Stretch="UniformToFill"/>
                                         </Border>
 
                                        <!-- Labels -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Free Fire" FontWeight="ExtraBlack" FontSize="15" Foreground="#FFFFFF" Margin="0,0,0,2"/>
                                            <TextBlock Name="TxtBypassEmu" Text="Emu: MSI" FontWeight="ExtraBold" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,2"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Engine: " FontWeight="ExtraBold" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Name="TxtBypassState" Text="Offline" FontWeight="ExtraBold" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                         <!-- Actions -->
                                         <StackPanel Grid.Column="2" VerticalAlignment="Center" Width="96">
                                             <Button Content="Connect" Height="28" FontSize="12" Margin="0,0,0,4" Click="ConnectBypass_Click">
                                                 <Button.Template>
                                                     <ControlTemplate TargetType="Button">
                                                         <Border Name="CBtn" CornerRadius="4" Background="#006F21" BorderBrush="#005619" BorderThickness="1">
                                                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                         </Border>
                                                         <ControlTemplate.Triggers>
                                                             <Trigger Property="IsMouseOver" Value="True">
                                                                 <Setter TargetName="CBtn" Property="Background" Value="#008728"/>
                                                                 <Setter TargetName="CBtn" Property="BorderBrush" Value="#006F21"/>
                                                             </Trigger>
                                                             <Trigger Property="IsPressed" Value="True">
                                                                 <Setter Property="RenderTransform">
                                                                     <Setter.Value>
                                                                         <ScaleTransform ScaleX="0.96" ScaleY="0.96" CenterX="48" CenterY="14"/>
                                                                     </Setter.Value>
                                                                 </Setter>
                                                             </Trigger>
                                                         </ControlTemplate.Triggers>
                                                     </ControlTemplate>
                                                 </Button.Template>
                                             </Button>
                                             <Button Content="Disconnect" Height="28" FontSize="12" Click="DisconnectBypass_Click">
                                                 <Button.Template>
                                                     <ControlTemplate TargetType="Button">
                                                         <Border Name="DBtn" CornerRadius="4" Background="#8C1D1D" BorderBrush="#701616" BorderThickness="1">
                                                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                         </Border>
                                                         <ControlTemplate.Triggers>
                                                             <Trigger Property="IsMouseOver" Value="True">
                                                                 <Setter TargetName="DBtn" Property="Background" Value="#A82727"/>
                                                                 <Setter TargetName="DBtn" Property="BorderBrush" Value="#8C1D1D"/>
                                                             </Trigger>
                                                             <Trigger Property="IsPressed" Value="True">
                                                                 <Setter Property="RenderTransform">
                                                                     <Setter.Value>
                                                                         <ScaleTransform ScaleX="0.96" ScaleY="0.96" CenterX="48" CenterY="14"/>
                                                                     </Setter.Value>
                                                                 </Setter>
                                                             </Trigger>
                                                         </ControlTemplate.Triggers>
                                                     </ControlTemplate>
                                                 </Button.Template>
                                             </Button>
                                         </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- PAGE 2: EMULATOR INSTALLER -->
                             <Grid Name="PageEmu" Visibility="Collapsed" VerticalAlignment="Center">
                                <Border CornerRadius="6" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" Padding="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#120C0D" Offset="0"/>
                                            <GradientStop Color="#0A0909" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <!-- Header -->
                                        <Border Padding="10,8,10,7" BorderThickness="0,0,0,1" BorderBrush="{StaticResource WidgetBorderBrush}">
                                            <Grid>
                                                <TextBlock Text="INSTALLER MENU" FontWeight="ExtraBold" FontSize="11" Foreground="#00FF33" VerticalAlignment="Center"/>
                                                <TextBlock Text="KERNEL DRIVER" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <!-- Content -->
                                        <StackPanel Margin="13">
                                            <!-- Dropdown and Request Access -->
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.15*"/>
                                                    <ColumnDefinition Width="0.85*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Emulator Selector Custom Combobox -->
                                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                                    <Border Name="EmuSelectTrigger" Height="30" Background="#070707" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="4" Cursor="Hand" MouseDown="EmuSelectTrigger_MouseDown" Padding="11,3">
                                                        <Grid>
                                                            <TextBlock Name="TxtSelectedEmu" Text="MSI Player" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="▼" FontSize="9" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    
                                                    <!-- Dropdown items popup container (rendered above elements) -->
                                                    <Popup Name="EmuSelectPopup" PlacementTarget="{Binding ElementName=EmuSelectTrigger}" Placement="Bottom" StaysOpen="True" PopupAnimation="Fade" AllowsTransparency="True">
                                                        <Border Width="176" Background="#0C0B0B" BorderBrush="{StaticResource PanelBorderHoverBrush}" BorderThickness="1" CornerRadius="4" Padding="0">
                                                            <StackPanel>
                                                                <!-- Option 1: MSI -->
                                                                <Border Name="EmuOptMsi" Background="{StaticResource CrimsonBrush}" Tag="MSI" Cursor="Hand" MouseDown="EmuOption_MouseDown" Padding="13,8">
                                                                    <TextBlock Text="MSI Player" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"/>
                                                                </Border>
                                                                <!-- Option 2: Bluestacks -->
                                                                <Border Name="EmuOptBlue" Background="Transparent" Tag="BlueStacks" Cursor="Hand" MouseDown="EmuOption_MouseDown" Padding="13,8">
                                                                    <TextBlock Text="Bluestacks" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </Border>
                                                    </Popup>
                                                </Grid>

                                                <Button Grid.Column="1" Content="REQUEST ACCESS" Style="{StaticResource ImguiButtonStyle}" Height="30" FontSize="11" Click="RequestAccess_Click"/>
                                            </Grid>

                                            <!-- Install / Uninstall certs -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="INSTALL CERT" Style="{StaticResource GreenButtonStyle}" Height="32" FontSize="11" Margin="0,0,4,0" Click="InstallCert_Click"/>
                                                <Button Grid.Column="1" Content="UNINSTALL CERT" Style="{StaticResource RedButtonStyle}" Height="32" FontSize="11" Margin="4,0,0,0" Click="UninstallCert_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- PAGE 3: PORTAL/WEB -->
                            <Grid Name="PageWeb" Visibility="Collapsed" VerticalAlignment="Center">
                                <Border CornerRadius="6" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" Background="#050505" Padding="0">
                                    <StackPanel>
                                        <!-- Header banner with user SVG icon -->
                                        <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource WidgetBorderBrush}" Padding="8,10,8,7">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="24" CornerRadius="5" Background="#26FF1E56" BorderBrush="#4DFF1E56" BorderThickness="1">
                                                    <Path Data="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M16 7 A 4 4 0 1 1 8 7 A 4 4 0 1 1 16 7" 
                                                          Stroke="{StaticResource CrimsonBrush}" StrokeThickness="2.5" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <TextBlock Text="UID Bypass Portal" FontWeight="ExtraBold" FontSize="12" Foreground="{StaticResource TextHighlightBrush}"/>
                                                    <TextBlock Text="deletehex.com" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Action link and text -->
                                        <StackPanel Margin="11,13">
                                            <Button Style="{StaticResource AccentButtonStyle}" Height="32" HorizontalAlignment="Stretch" Cursor="Hand" Click="OpenWebPortal_Click">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <!-- External link symbol -->
                                                    <Path Data="M 10 13 A 5 5 0 0 0 17.54 13.54 L 20.54 10.54 A 5 5 0 0 0 13.47 3.47 L 11.75 5.18 M 14 11 A 5 5 0 0 0 6.46 10.46 L 3.46 13.46 A 5 5 0 0 0 10.53 20.53 L 12.24 18.82" 
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="3" Width="11" Height="11" Stretch="Uniform"/>
                                                    <TextBlock Text="OPEN WEB PORTAL" Margin="5,0,0,0" FontSize="12" FontWeight="ExtraBold"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBlock Text="Login with your bypass key to access premium features" Margin="0,5,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" LineHeight="1.4"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </Grid>
                    </Grid>
                </Grid>

                <!-- LED Indicator dot under the logo box (used as decoration in bottom pane) -->
                <Grid Grid.Row="1" IsHitTestVisible="False">
                    <!-- LED Light that glows -->
                    <Border Name="BypassLedGlow" Width="8" Height="8" CornerRadius="4" 
                            Background="{StaticResource CrimsonBrush}" 
                            HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,10"
                            Visibility="Collapsed">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF1E56" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BypassLedScale" ScaleX="1.0" ScaleY="1.0" CenterX="4" CenterY="4"/>
                        </Border.RenderTransform>
                    </Border>
                </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Decorative CRT scanline Overlay (hit-test disabled) -->
        <Border Name="CrtOverlay" Width="412" Height="292" 
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{StaticResource ScanlinesBrush}"
                CornerRadius="6"
                IsHitTestVisible="False"
                Opacity="0.35"
                Visibility="Collapsed"/>

        <!-- Restore Window Button (shows when window is closed) -->
        <Button Name="ImguiRestoreButton" Content="📂 Restore UID Bypass" Style="{StaticResource AccentButtonStyle}" 
                Width="172" Height="42" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Visibility="Collapsed" Cursor="Hand" Click="ImguiRestoreButton_Click">
            <Button.Effect>
                <DropShadowEffect Color="#FF1E56" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
            </Button.Effect>
        </Button>
    </Grid>
</Window>
